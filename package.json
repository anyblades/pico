{
  "name": "@anyblades/pico",
  "version": "2.4.2",
  "description": "Minimal CSS Framework for semantic HTML",
  "author": "Lucas Larroche",
  "contributors": [
    "Anton Staroverov"
  ],
  "exports": {
    ".": "./src/pico.css"
  },
  "homepage": "https://blades.ninja/css/pico/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anyblades/pico.git"
  },
  "publishConfig": {
    "tag": "next"
  },
  "keywords": [
    "css",
    "css-framework",
    "dark-mode",
    "dark-theme",
    "lightweight",
    "minimal",
    "minimalist",
    "minimalistic",
    "native-html",
    "scss-framework",
    "semantic"
  ],
  "bugs": {
    "url": "https://github.com/anyblades/pico/issues"
  },
  "scripts": {
    "build": "npm run lint && npm run build:css && npm run build:minify",
    "lint": "prettier --write --log-level silent 'src/**/*.css'",
    "build:css": "postcss --config css 'src/!(_)*.css' --dir css --no-map",
    "build:minify": "cleancss -O1 --with-rebase --batch --batch-suffix .min css/*.css !css/*.min.css"
  },
  "devDependencies": {
    "@anyblades/blades": "^2.4.3",
    "autoprefixer": "^10.4.21",
    "clean-css-cli": "^5.6.3",
    "css-declaration-sorter": "^7.2.0",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.5.3"
  },
  "browserslist": [
    "defaults"
  ]
}