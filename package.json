{
  "name": "@anyblades/pico",
  "version": "2.2.2",
  "description": "Minimal CSS Framework for semantic HTML",
  "author": "Lucas Larroche",
  "contributors": [
    "Anton Staroverov"
  ],
  "style": "css/pico.min.css",
  "exports": {
    ".": "./src/pico.css"
  },
  "homepage": "https://picocss.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anyblades/pico.git"
  },
  "publishConfig": {
    "tag": "next"
  },
  "keywords": [
    "css",
    "css-framework",
    "dark-mode",
    "dark-theme",
    "lightweight",
    "minimal",
    "minimalist",
    "minimalistic",
    "native-html",
    "scss-framework",
    "semantic"
  ],
  "bugs": {
    "url": "https://github.com/anyblades/pico/issues"
  },
  "scripts": {
    "✨": "npm run -s build",
    "build": "npm run -s start && npm run -s lint && npm run -s build:css && npm run -s build:themes && npm run -s build:autoprefix && npm run -s build:minify && npm run -s done",
    "dev": "nodemon -q --watch scss/ --ext scss --exec 'npm run -s build'",
    "lint": "npm run -s prelint && npm run -s lint:prettier && npm run -s lint:sort-scss",
    "lint:prettier": "prettier --write --log-level silent 'scss/**/*.scss'",
    "lint:sort-scss": "postcss --config scss ./scss/**/*.scss --replace",
    "build:css": "npm run -s prebuild:css && sass --no-source-map --style expanded --no-error-css scss/:css/",
    "build:themes": "npm run -s prebuild:themes && node scripts/build-themes",
    "build:autoprefix": "npm run -s prebuild:autoprefix && postcss --config css --replace css/*.css !css/*.min.css",
    "build:minify": "npm run -s prebuild:minify && cleancss -O1 --with-rebase --batch --batch-suffix .min css/*.css !css/*.min.css",
    "prelint": "echo '[@picocss/pico] ✨ Lint'",
    "prebuild:css": "echo '[@picocss/pico] ✨ Compile'",
    "prebuild:themes": "echo '[@picocss/pico] ✨ Compile themes'",
    "prebuild:autoprefix": "echo '[@picocss/pico] ✨ Autoprefix'",
    "prebuild:minify": "echo '[@picocss/pico] ✨ Minify'",
    "start": "echo '\\033[96m[@picocss/pico] ✨ Start\\033[0m'",
    "done": "echo '\\033[32m[@picocss/pico] ✨ Done\\033[0m'"
  },
  "devDependencies": {
    "@anyblades/blades": "^2.2.0",
    "autoprefixer": "^10.4.21",
    "caniuse-lite": "1.0.30001704",
    "clean-css-cli": "^5.6.3",
    "css-declaration-sorter": "^7.2.0",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.5.3"
  },
  "browserslist": [
    "defaults"
  ]
}
