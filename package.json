{
  "name": "@anyblades/pico",
  "version": "2.2.0-alpha.4",
  "description": "Minimal CSS Framework for semantic HTML",
  "author": "Lucas Larroche",
  "contributors": [
    "Anton Staroverov"
  ],
  "style": "css/pico.min.css",
  "exports": {
    ".": "./src/pico.css"
  },
  "homepage": "https://picocss.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anyblades/pico.git"
  },
  "publishConfig": {
    "tag": "next"
  },
  "keywords": [
    "css",
    "css-framework",
    "dark-mode",
    "dark-theme",
    "lightweight",
    "minimal",
    "minimalist",
    "minimalistic",
    "native-html",
    "scss-framework",
    "semantic"
  ],
  "bugs": {
    "url": "https://github.com/anyblades/pico/issues"
  },
  "scripts": {
    "✨": "run-s build",
    "build": "run-s start lint \"build:*\" done --silent",
    "dev": "nodemon -q --watch scss/ --ext scss --exec 'run-s build'",
    "lint": "run-s \"lint:*\" --silent",
    "lint:prettier": "prettier --write --log-level silent 'src/**/*.css'",
    "build:css": "postcss --config css 'src/!(_)*.css' --dir css --no-map",
    "build:minify": "cleancss -O1 --with-rebase --batch --batch-suffix .min css/*.css !css/*.min.css",
    "prelint": "echo '[@anyblades/pico] ✨ Lint'",
    "prebuild:css": "echo '[@anyblades/pico] ✨ Compile'",
    "prebuild:minify": "echo '[@anyblades/pico] ✨ Minify'",
    "start": "echo '\\033[96m[@anyblades/pico] ✨ Start\\033[0m'",
    "done": "echo '\\033[32m[@anyblades/pico] ✨ Done\\033[0m'"
  },
  "devDependencies": {
    "@anyblades/blades": "^0.28.0-alpha.2",
    "autoprefixer": "^10.4.21",
    "caniuse-lite": "1.0.30001704",
    "clean-css-cli": "^5.6.3",
    "css-declaration-sorter": "^7.2.0",
    "nodemon": "^3.1.9",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.5.3"
  },
  "browserslist": [
    "defaults"
  ]
}
